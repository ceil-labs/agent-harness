# Agent Harness Configuration
# Copy this file to .env and customize
#
# Secrets are managed separately via:
#   bin/harness secrets_init  # First time only
#   bin/harness secrets_edit  # Add/edit secrets
#   bin/harness secrets_list  # View secret names

# Agent Identity
# ---------------
AGENT_ID=ceil-phase0

# LLM Configuration
# -----------------
MODEL=k2p5

# Logging
# -------
# Options: debug, info, warn, error
LOG_LEVEL=info

# Health Check
# ------------
# Interval for periodic health checks in seconds (default: 300 / 5 minutes)
# Set to 60 for 1-minute checks, 300 for 5-minute checks, etc.
# Note: Periodic checks use lightweight mode (no API call) for efficiency
HEALTH_CHECK_INTERVAL=300

# Metrics Server
# ---------------
# Prometheus metrics endpoint port
METRICS_PORT=9090

# Allowlist (Optional)
# --------------------
# Comma-separated Telegram user IDs allowed to message the bot
# Leave empty to allow all users
# Example: ALLOWLIST=123456789,987654321
ALLOWLIST=

# System Prompt (Optional)
# -------------------------
# Override the default system prompt
# Default: "You are Ceil, a helpful AI assistant. Be concise and friendly."
# SYSTEM_PROMPT=You are Ceil, a helpful AI assistant. Be concise and friendly.

# Grafana Configuration
# --------------------
# Grafana admin credentials (change in production)
GRAFANA_ADMIN_USER=harness
GRAFANA_ADMIN_PASSWORD=harness