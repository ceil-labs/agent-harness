#!/usr/bin/env ruby
# frozen_string_literal: true

# Security audit script for agent-harness
# Usage: bin/security-audit

require "bundler/audit"
require "bundler/audit/cli"

puts "🔒 Agent Harness Security Audit"
puts "=" * 50

# Update vulnerability database
puts "\n📦 Updating vulnerability database..."
Bundler::Audit::Database.update!

# Run audit
puts "\n🔍 Scanning for vulnerable gems..."
result = Bundler::Audit::CLI.start(["check"])

if result == 0
  puts "\n✅ No vulnerabilities found!"
  exit 0
else
  puts "\n⚠️  Vulnerabilities detected - review above"
  exit 1
end
