#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "thor"
require "agent_harness"

module AgentHarness
  class CLI < Thor
    # Thor 1.3+ compatibility
    def self.exit_on_failure?
      true
    end

    desc "secrets_init", "Initialize secrets with new master key"
    def secrets_init
      key = Secrets::FileProvider.init(master_key_path: "config/master.key")
      puts "✅ Master key generated: config/master.key"
      puts "🔒 Key (base64): #{key[0..20]}..."
      puts "⚠️  Keep this file secure! Add to .gitignore"
    end

    desc "secrets_edit", "Edit encrypted secrets"
    def secrets_edit
      provider = create_provider
      provider.edit
      puts "✅ Secrets updated: config/secrets.yml.enc"
    end

    desc "secrets_list", "List secret names (not values)"
    def secrets_list
      provider = create_provider
      names = provider.list

      if names.empty?
        puts "No secrets found. Run `bin/harness secrets_edit` to add some."
      else
        puts "🔐 Secrets:"
        names.each { |n| puts "  - #{n}" }
      end
    end

    desc "security_audit", "Run security audit"
    def security_audit
      exec("bin/security-audit")
    end

    private

    def create_provider
      Secrets::FileProvider.new(
        master_key_path: "config/master.key",
        secrets_path: "config/secrets.yml.enc"
      )
    end
  end
end

AgentHarness::CLI.start(ARGV)
